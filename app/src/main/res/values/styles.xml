    <style name="SubHeadline_20medium">
        <item name="fontFamily">@font/pretendard_medium</item>
        <item name="android:textSize">20sp</item>
        <item name="lineHeight">26sp</item>
        <item name="android:textColor">@color/gray_700</item>
    </style>

    <style name="SubHeadline_20semibold">
        <item name="fontFamily">@font/pretendard_semibold</item>
        <item name="android:textSize">20sp</item>
