<?xml version="1.0" encoding="utf-8"?>

<!-- Widget.Untitled.[Component].[역할 또는 특징] -->
<resources>

    <!-- Radius가 적용된 기본 버튼 베이스 -->
    <style name="Widget.Untitled.Button.Base" parent="Widget.Material3.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- 버튼 활성화 여부에 따라 배경색이 바뀌는 버튼 -->
    <style name="Widget.Untitled.Button.StateToggle" parent="Widget.Untitled.Button.Base">
        <item name="backgroundTint">@color/btn_state_toggle_bg</item>
        <item name="android:textColor">@color/btn_text_state_toggle</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Untitled.Button.ClickedToggle" parent="Widget.Untitled.Button.Base">
        <item name="backgroundTint">@color/btn_clicked_toggle_bg</item>
        <item name="android:textColor">@color/btn_text_clicked_toggle</item>
        <item name="android:textStyle">bold</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/btn_stroke_clicked_toggle</item>
    </style>

    <style name="Widget.Untitled.Button.TimeSlot" parent="Widget.Material3.Button">
        <item name="cornerRadius">6dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:inset">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">18sp</item>
        <item name="backgroundTint">@color/gray_100</item>
        <item name="android:textColor">@color/gray_700</item>
    </style>

    <!-- fullScreen 다이얼로그-->
    <style name="ThemeOverlay.Untitled.FullscreenDialog" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!--상태 칩 -->
    <style name="Widget.Untitled.Chip.StateBase" parent="Widget.Material3.Chip.Assist">
        <item name="cornerRadius">5dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textSize">14sp</item>
        <item name="checkedIconVisible">false</item>
        <item name="android:checkable">false</item>
        <item name="android:paddingHorizontal">10dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="rippleColor">@android:color/transparent</item>
    </style>

    <!--면접 진행 칩-->
    <style name="Widget.Untitled.Chip.Interview" parent="Widget.Untitled.Chip.StateBase">
        <item name="chipBackgroundColor">#E1EEF9</item>
        <item name="android:textColor">#487CE3</item>
    </style>
    <!--모집 마감 칩-->
    <style name="Widget.Untitled.Chip.Closed" parent="Widget.Untitled.Chip.StateBase">
        <item name="chipBackgroundColor">#FAE1E1</item>
        <item name="android:textColor">#D75E5E</item>
    </style>
    <!--면접 진행 칩-->
    <style name="Widget.Untitled.Chip.Open" parent="Widget.Untitled.Chip.StateBase">
        <item name="chipBackgroundColor">#DFEFE5</item>
        <item name="android:textColor">#249C7A</item>
    </style>


    <!--rootToolbar text Style-->
    <style name="ToolbarTitle.Root" parent="@style/TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textSize">22sp</item>
    </style>

    <!--datailToolbar text Style-->
    <style name="ToolbarTitle.Detail" parent="@style/TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="EditTextStyle">
        <item name="android:background">@drawable/input_selector_bg</item>
        <item name="android:padding">18dp</item>
        <item name="android:textColor">@color/gray_700</item>
        <item name="android:textColorHint">@color/gray_500</item>
        <item name="android:textSize">16sp</item>
        <item name="android:gravity">start</item>
    </style>

    <!--TextInput 스타일-->
    <style name="Widget.Untitled.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_toggle</item>
        <item name="boxBackgroundMode">outline</item>
        <item name="boxCornerRadiusBottomEnd">10dp</item>
        <item name="boxCornerRadiusBottomStart">10dp</item>
        <item name="boxCornerRadiusTopEnd">10dp</item>
        <item name="boxCornerRadiusTopStart">10dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxBackgroundColor">@android:color/transparent</item>
        <item name="boxStrokeWidthFocused">1dp</item>


        <item name="errorTextColor">@color/accent_red</item>
        <item name="boxStrokeErrorColor">@color/accent_red</item>
        <item name="errorIconDrawable">@null</item>
    </style>

    <!--이용약관용 다이얼로그 스타일-->
    <style name="ThemeOverlay.Untitled.BottomSheet" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.Untitled.BottomSheet</item>
    </style>

    <style name="Widget.Untitled.BottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearance">@style/ShapeAppearance.Untitled.NoCorners</item>
        <item name="backgroundTint">@color/white</item>
    </style>

    <style name="ShapeAppearance.Untitled.NoCorners" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">0dp</item>
    </style>
</resources>