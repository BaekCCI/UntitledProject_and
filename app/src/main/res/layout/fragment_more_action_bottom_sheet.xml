<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="31dp"
    tools:context=".ui.board.dialogs.MoreActionBottomSheetFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:background="@drawable/rounded_bg"
        android:backgroundTint="@color/gray_50"
        android:orientation="vertical"
        android:padding="18dp">


        <com.google.android.material.button.MaterialButton
            android:id="@+id/editBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:background="@android:color/transparent"
            android:backgroundTint="@null"
            android:text="수정하기"
            android:textColor="@color/gray_700"
            android:textSize="18sp"
            app:icon="@drawable/ic_pen"
            app:iconGravity="textStart"
            app:iconSize="24dp"
            app:iconTint="@color/gray_700" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginBottom="10dp"
            android:background="@color/gray_300" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:backgroundTint="@null"
            android:text="삭제하기"
            android:textColor="@color/accent_red"
            android:textSize="18sp"
            app:icon="@drawable/ic_trash"
            app:iconGravity="textStart"
            app:iconSize="24dp"
            app:iconTint="@color/accent_red" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeBtn"
        style="@style/Widget.Untitled.Button.Base"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="@android:color/transparent"
        android:text="닫기"
        android:textColor="@color/gray_500"
        android:textSize="18sp" />

</LinearLayout>