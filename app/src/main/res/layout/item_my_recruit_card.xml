<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:contentPadding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 상단: 공고 정보 + 썸네일 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 좌측: 공고 정보 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/categoryTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="영상동아리"
                    android:textColor="@android:color/black"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/titleTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="영상동아리 OO 모집합니다."
                    android:textColor="@android:color/black"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/statusTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="모집중"
                    android:textColor="@android:color/darker_gray"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- 우측: 썸네일 이미지 -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:id="@+id/thumbnailImg"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E0E0E0"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_background" />

                <!-- 이미지 개수 표시 (오른쪽 상단) -->
                <TextView
                    android:id="@+id/imageCountTxt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="4dp"
                    android:background="@android:color/black"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:text="1/3"
                    android:textColor="@android:color/white"
                    android:textSize="10sp" />

            </FrameLayout>

        </LinearLayout>

        <!-- 하단: 관리 버튼들 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/interviewManageBtn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="4dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="면접 예약 관리"
                android:textColor="@android:color/black"
                android:textSize="12sp"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/applicantManageBtn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginHorizontal="4dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="지원자 관리"
                android:textColor="@android:color/black"
                android:textSize="12sp"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/postManageBtn"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:text="작성글 관리"
                android:textColor="@android:color/black"
                android:textSize="12sp"
                style="?android:attr/borderlessButtonStyle" />

        </LinearLayout>

        <!-- 페이지 인디케이터 -->
        <LinearLayout
            android:id="@+id/pageIndicatorLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="4dp"
                android:background="@android:color/darker_gray"
                android:backgroundTint="#666666" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@android:color/darker_gray"
                android:backgroundTint="#CCCCCC" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>