<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.board.write.InfoWriteFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="16dp">

                <include
                    android:id="@+id/stepIndicator"
                    layout="@layout/step_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="42dp"
                    android:text="지원자로부터\n수집할 정보를 선택해주세요"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:text="기본 정보"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1개 이상"
                        android:textColor="@color/gray_500"
                        android:textSize="14sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 수집 정보 버튼들 -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/nameCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="지원자 이름"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/genderCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="성별"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/ageCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="나이"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/majorCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="학과/전공"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/studentNumberCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="학번"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />

                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/phoneCheckBox"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/checkbox_bg_selector"
                        android:button="@drawable/ic_checkbox_selector"
                        android:layoutDirection="rtl"
                        android:text="연락처"
                        android:textColor="@color/check_box_text_selector"
                        android:textSize="16sp"
                        app:buttonTint="@null" />
                </LinearLayout>

                <!-- 커스텀 질문 레이아웃 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="필수 질문"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/customQuestionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/addQuestionBtn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="커스텀 질문 추가하기" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="162dp"
                    android:layout_gravity="bottom"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/prevBtn"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:text="이전"
                        android:textColor="@color/white"
                        app:backgroundTint="@null" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/completeBtn"
                        style="@style/Widget.Untitled.Button.StateToggle"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:enabled="false"
                        android:text="공고 올리기" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>


</FrameLayout>