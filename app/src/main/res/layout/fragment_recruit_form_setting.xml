<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".ui.board.write.InfoWriteFragment">


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="50dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginEnd="10dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/indicator_dot_unselected" />

                </FrameLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginEnd="10dp">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/indicator_dot_unselected" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="23dp"
                        android:layout_height="23dp"
                        android:background="@drawable/indicator_dot_selected"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/white" />
                </FrameLayout>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="지원자로부터\n수집할 정보를 선택해주세요"
                android:textAppearance="@style/Headline_24semibold"
                android:textColor="@color/gray_800" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:drawablePadding="4dp"
                android:text="모집글 작성이 완료되면 수정할 수 없어요"
                android:textAppearance="@style/Caption_14medium"
                android:textColor="@color/gray_500"
                app:drawableStartCompat="@drawable/ic_error" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="8dp"
                    android:text="기본 정보"
                    android:textAppearance="@style/Caption_14semibold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1개 이상"
                    android:textAppearance="@style/Caption_14regular"
                    android:textColor="@color/gray_500" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:orientation="vertical">

                <!-- 수집 정보 버튼들 -->
                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/nameCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/checkbox_bg_selector"
                    android:button="@drawable/ic_checkbox_selector"
                    android:checked="true"
                    android:clickable="false"
                    android:enabled="false"
                    android:layoutDirection="rtl"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="지원자 이름"
                    android:textAppearance="@style/Body2_16medium"
                    android:textColor="@color/check_box_text_selector"
                    app:buttonTint="@color/point_skyblue_tinted" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/genderCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/checkbox_bg_selector"
                    android:button="@drawable/ic_checkbox_selector"
                    android:layoutDirection="rtl"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="성별"
                    android:textAppearance="@style/Body2_16medium"
                    android:textColor="@color/check_box_text_selector"
                    app:buttonTint="@null" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/ageCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/checkbox_bg_selector"
                    android:button="@drawable/ic_checkbox_selector"
                    android:layoutDirection="rtl"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="나이"
                    android:textAppearance="@style/Body2_16medium"
                    android:textColor="@color/check_box_text_selector"
                    app:buttonTint="@null" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/majorCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/checkbox_bg_selector"
                    android:button="@drawable/ic_checkbox_selector"
                    android:layoutDirection="rtl"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="학과/전공"
                    android:textAppearance="@style/Body2_16medium"
                    android:textColor="@color/check_box_text_selector"
                    app:buttonTint="@null" />

                <com.google.android.material.checkbox.MaterialCheckBox
                    android:id="@+id/studentNumberCheckBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/checkbox_bg_selector"
                    android:button="@drawable/ic_checkbox_selector"
                    android:layoutDirection="rtl"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:text="학번"
                    android:textAppearance="@style/Body2_16medium"
                    android:textColor="@color/check_box_text_selector"
                    app:buttonTint="@null" />

                <!--                <com.google.android.material.checkbox.MaterialCheckBox-->
                <!--                    android:id="@+id/phoneCheckBox"-->
                <!--                    android:layout_width="match_parent"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginTop="12dp"-->
                <!--                    android:background="@drawable/checkbox_bg_selector"-->
                <!--                    android:button="@drawable/ic_checkbox_selector"-->
                <!--                    android:layoutDirection="rtl"-->
                <!--                    android:paddingHorizontal="16dp"-->
                <!--                    android:paddingVertical="14dp"-->
                <!--                    android:text="연락처"-->
                <!--                    android:textAppearance="@style/Body2_16medium"-->
                <!--                    android:textColor="@color/check_box_text_selector"-->
                <!--                    app:buttonTint="@null" />-->

            </LinearLayout>

            <!-- 커스텀 질문 레이아웃 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="8dp"
                        android:text="필수 질문"
                        android:textAppearance="@style/Caption_14semibold"
                        android:textColor="@color/gray_700" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1개 이상"
                        android:textAppearance="@style/Caption_14regular"
                        android:textColor="@color/gray_500" />
                </LinearLayout>


                <LinearLayout
                    android:id="@+id/customQuestionContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout
                    android:id="@+id/addQuestionBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_bg"
                    android:backgroundTint="@color/gray_100"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingVertical="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:text="커스텀 질문 추가하기"
                        android:textAppearance="@style/Body1_16medium"
                        android:textColor="@color/point_skyblue" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_add_circle_filled" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_action_container_bg"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/prevBtn"
            style="@style/Widget.Untitled.Button.ClickedToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:layout_weight="1"
            android:text="이전" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/completeBtn"
            style="@style/Widget.Untitled.Button.StateToggle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:enabled="false"
            android:text="모집글 올리기" />
    </LinearLayout>
</LinearLayout>

