<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/submit_application_nav"
    app:startDestination="@id/applicationFormFragment">

    <fragment
        android:id="@+id/applicationFormFragment"
        android:name="com.baek.untitledproject.ui.board.apply.ApplicationFormFragment"
        android:label="fragment_application_form"
        tools:layout="@layout/fragment_application_form">
        <argument
            android:name="postId"
            app:nullable="false"
            app:argType="string" />
        <action
            android:id="@+id/action_applicationFormFragment_to_previewFragment"
            app:destination="@id/previewFragment" />
    </fragment>
    <fragment
        android:id="@+id/previewFragment"
        android:name="com.baek.untitledproject.ui.board.apply.PreviewFragment"
        android:label="fragment_preview"
        tools:layout="@layout/fragment_preview" >
        <action
            android:id="@+id/action_previewFragment_to_completeApplyFragment"
            app:destination="@id/completeApplyFragment"
            app:popUpTo="@id/applicationFormFragment"
            app:popUpToInclusive="true"
            app:launchSingleTop="true"/>
    </fragment>
    <fragment
        android:id="@+id/completeApplyFragment"
        android:name="com.baek.untitledproject.ui.board.apply.CompleteApplyFragment"
        android:label="fragment_complete_apply"
        tools:layout="@layout/fragment_complete_apply" />
</navigation>